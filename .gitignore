# Ignore Python cache and virtual environments
__pycache__/
*.py[cod]
*.so
.venv/
venv/

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore data and model weights
/data/
*.pt
*.pth
*.h5
*.ckpt

# Allow model artifacts inside models/ (so friends can run the app)
!models/*.pt
!models/*.npz
!models/*.json

# Too large for normal GitHub pushes (use Git LFS if you really want it)
models/best_model.pt

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore environment and config files
.env
*.env

# Ignore logs
*.log

# Ignore VSCode settings
.vscode/
kaggle.json
data/